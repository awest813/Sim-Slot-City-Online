{
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/*.test.ts", "**/*.spec.ts"],
  "collectCoverageFrom": ["src/**/*.ts", "!src/index.ts"],
  "moduleNameMapper": {
    "^@slot-city/shared$": "<rootDir>/../../packages/shared/src/index.ts"
  },
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": {
          "baseUrl": ".",
          "paths": {
            "@slot-city/shared": ["../../packages/shared/src/index.ts"]
          }
        }
      }
    ]
  }
}
