# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/slot_city?schema=public"

# JWT Secret — CHANGE THIS IN PRODUCTION
JWT_SECRET="slot-city-dev-secret-change-in-prod"

# Server
PORT=2567
NODE_ENV=development

# CORS — origin of the web shell
CORS_ORIGIN="http://localhost:3000"

# Game server URL (used by Next.js web shell for rewrites)
GAME_SERVER_URL="http://localhost:2567"

# Game client URL (used by Next.js to link to the game)
NEXT_PUBLIC_GAME_CLIENT_URL="http://localhost:3001"

# Game server URL (public, used by Next.js pages)
NEXT_PUBLIC_GAME_SERVER_URL="http://localhost:2567"

# Colyseus (used by Phaser client)
VITE_SERVER_URL="ws://localhost:2567"
VITE_API_URL="http://localhost:2567"
