{
    "name": "slot-city-client",
    "description": "Slot City — browser-based multiplayer isometric social casino (Phaser 3 game client).",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite --config vite/config.dev.mjs",
        "build": "tsc --noEmit && vite build --config vite/config.prod.mjs",
        "preview": "vite preview --config vite/config.prod.mjs",
        "dev:full": "npm run dev --prefix slot-city",
        "dev:client": "npm run dev --prefix slot-city/apps/game-client",
        "test": "npm run test --prefix slot-city"
    },
    "devDependencies": {
        "typescript": "~5.7.2",
        "vite": "^6.3.1"
    },
    "dependencies": {
        "phaser": "^3.90.0",
        "terser": "^5.39.0"
    }
}
